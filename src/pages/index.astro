---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio">
  <main>
    <section class="hero container animate-fade-in">
      <div class="hero-content">
        <h1 class="title">Hola, soy <span class="gradient-text">Sergio</span>.</h1>
        <p class="subtitle">
          Desarrollador enfocado en crear experiencias web excepcionales.
        </p>
        <div class="cta-buttons">
          <a href="#proyectos" class="btn btn-primary">Ver mis proyectos</a>
          <a href="#contacto" class="btn btn-secondary">Contactar</a>
        </div>
      </div>
      <div class="hero-image">
        <div class="image-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <line x1="19" y1="8" x2="19" y2="14" />
            <line x1="22" y1="11" x2="16" y2="11" />
          </svg>
        </div>
      </div>
    </section>

    <section id="proyectos" class="projects container">
      <h2 class="section-title">Proyectos Destacados</h2>
      <div class="projects-grid">
        <article class="project-card">
          <div class="project-image-placeholder"></div>
          <div class="project-info">
            <h3>Proyecto Alpha</h3>
            <p>Una aplicación web moderna y rápida construida con las últimas tecnologías del mercado.</p>
            <div class="tags">
              <span class="tag">Astro</span>
              <span class="tag">JavaScript</span>
            </div>
            <a href="#" class="view-link">Ver detalles &rarr;</a>
          </div>
        </article>
        
        <article class="project-card">
          <div class="project-image-placeholder"></div>
          <div class="project-info">
            <h3>API Dashboard</h3>
            <p>Panel de administración con estadísticas en tiempo real y gestión de usuarios avanzada.</p>
            <div class="tags">
              <span class="tag">PHP</span>
              <span class="tag">Vue.js</span>
            </div>
            <a href="#" class="view-link">Ver detalles &rarr;</a>
          </div>
        </article>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    margin-top: 4rem;
  }

  /* --- Hero Section --- */
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
    min-height: 80vh;
  }

  .hero-content {
    flex: 1;
    max-width: 600px;
  }

  .title {
    font-size: 4rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -1px;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--color-secondary);
    margin-bottom: 2.5rem;
    line-height: 1.8;
    opacity: 0.9;
  }

  .cta-buttons {
    display: flex;
    gap: 1.5rem;
  }

  .btn {
    padding: 0.8rem 1.8rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 14px 0 rgba(59, 130, 246, 0.39);
  }

  .btn-primary:hover {
    background: var(--color-accent);
    transform: translateY(-2px);
    color: white;
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
  }

  .btn-secondary {
    background: transparent;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.4);
    color: white;
  }

  .hero-image {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .image-placeholder {
    width: 350px;
    height: 350px;
    background: linear-gradient(145deg, rgba(59, 130, 246, 0.1), rgba(99, 102, 241, 0.1));
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    color: var(--color-primary);
    border: 2px solid rgba(59, 130, 246, 0.2);
    box-shadow: 0 0 50px rgba(59, 130, 246, 0.1);
  }

  /* --- Projects Section --- */
  .projects {
    padding: 6rem 1rem;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 3rem;
    text-align: center;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2.5rem;
  }

  .project-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .project-image-placeholder {
    height: 200px;
    background: linear-gradient(45deg, #1e293b, #0f172a);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .project-info {
    padding: 2rem;
  }

  .project-info h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .project-info p {
    color: var(--color-secondary);
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .tags {
    display: flex;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.3rem 0.8rem;
    background: rgba(59, 130, 246, 0.1);
    color: var(--color-primary);
    border-radius: 100px;
    font-weight: 600;
  }

  .view-link {
    font-weight: 600;
    font-size: 0.9rem;
    display: inline-flex;
    align-items: center;
  }

  .view-link:hover {
    transform: translateX(3px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
      text-align: center;
      padding-top: 2rem;
    }
    .cta-buttons {
      justify-content: center;
    }
    .title {
      font-size: 3rem;
    }
    .image-placeholder {
      width: 250px;
      height: 250px;
    }
  }
</style>
